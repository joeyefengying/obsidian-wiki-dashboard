{
  "name": "obsidian-wiki-dashboard",
  "version": "1.0.0",
  "description": "个人知识库仪表盘 — 快速消化、统计面板、最近活动、快捷操作一站式 Obsidian 插件",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "obsidian-plugin", "dashboard", "wiki", "knowledge-base"],
  "author": "张浩",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
